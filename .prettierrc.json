{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": false,
  "singleQuote": true,
  "arrowParens": "always",
  "bracketSameLine": true,
  "vueIndentScriptAndStyle": false,
  "trailingComma": "es5",
  "htmlWhitespaceSensitivity": "css",
  "bracketSpacing": true,
  "printWidth": 100
}
